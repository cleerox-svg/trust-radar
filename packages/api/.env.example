# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/lrx_api

# ─── Security ─────────────────────────────────────────────────
SECRET_KEY=your-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Redis (optional caching) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Cloudflare (for inter-service calls) ────────────────────
CF_RADAR_URL=https://trustradar.ca
CF_IMPRSN8_URL=https://imprsn8.com
INTERNAL_API_KEY=your-internal-api-key

# ─── Monitoring ──────────────────────────────────────────────
SENTRY_DSN=

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://trustradar.ca,https://imprsn8.com,http://localhost:3000
