{
  "name": "@averrow/marketing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Averrow corporate marketing site (averrow.com). Astro + MDX, output served by the trust-radar Worker via its Static Assets binding.",
  "scripts": {
    "dev": "astro dev --port 4321",
    "build": "astro build && node scripts/sync-to-worker.mjs",
    "preview": "astro preview --port 4321",
    "astro": "astro",
    "typecheck": "astro check"
  },
  "dependencies": {
    "astro": "^4.16.18",
    "@astrojs/mdx": "^3.1.9",
    "@astrojs/react": "^3.6.3",
    "@astrojs/rss": "^4.0.10",
    "@astrojs/sitemap": "^3.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  }
}
