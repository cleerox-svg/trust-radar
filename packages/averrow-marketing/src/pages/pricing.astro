<script>
  // Monthly/annual toggle. Mirror of the inline-template setPricing().
  (function () {
    const monthlyBtn = document.getElementById("pricing-monthly");
    const annualBtn = document.getElementById("pricing-annual");
    const monthlyEls = document.querySelectorAll<HTMLElement>(".price-monthly");
    const annualEls = document.querySelectorAll<HTMLElement>(".price-annual");

    function setPricing(mode: "monthly" | "annual") {
      monthlyEls.forEach(el => (el.style.display = mode === "monthly" ? "block" : "none"));
      annualEls.forEach(el => (el.style.display = mode === "annual" ? "block" : "none"));
      monthlyBtn?.classList.toggle("active", mode === "monthly");
      annualBtn?.classList.toggle("active", mode === "annual");
    }

    monthlyBtn?.addEventListener("click", () => setPricing("monthly"));
    annualBtn?.addEventListener("click", () => setPricing("annual"));
  })();

  // FAQ toggle.
  document.querySelectorAll<HTMLButtonElement>("[data-faq-toggle]").forEach(btn => {
    btn.addEventListener("click", () => btn.parentElement?.classList.toggle("open"));
  });
</script>
