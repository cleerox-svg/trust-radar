---
/*
 * Report Abuse page. Mailto-only intake (per Item 2.5 scope decision).
 * Three cards routing to phishing@ / abuse@ / abuse@ with checklists.
 * Ported from packages/averrow-worker/src/templates/report-abuse.ts.
 */
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
  title="Report Brand Abuse — Averrow"
  description="Report phishing emails, brand impersonation, lookalike domains, or counterfeit activity to Averrow. Forward suspicious messages to phishing@averrow.ca or email abuse@averrow.ca directly."
>
  <section class="abuse-hero">
    <div class="container">
      <div class="section-label">Report Abuse</div>
      <h1 class="section-title">Saw something suspicious?</h1>
      <p class="section-desc">
        If you&rsquo;ve received a phishing email, found a fake account
        claiming to be Averrow, or spotted a lookalike domain &mdash;
        send it to us. We triage every report and take action on every
        confirmed abuse case.
      </p>
    </div>
  </section>

  <div class="abuse-grid">
    <div class="abuse-card">
      <div class="abuse-card-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <path d="M3 7l9 6 9-6" />
          <path d="M9.5 15l1.5-1.5L9.5 12" />
        </svg>
      </div>
      <div class="abuse-card-title">Phishing Email</div>
      <div class="abuse-card-desc">
        Suspicious message claiming to be from Averrow, your bank, or any
        other brand. Forward it as an attachment so we get the full
        headers.
      </div>
      <ul class="abuse-card-checklist">
        <li>Forward as attachment (preserves headers &amp; SPF/DKIM)</li>
        <li>Or paste the full source if forwarding isn&rsquo;t possible</li>
        <li>Don&rsquo;t click links or open attachments first</li>
      </ul>
      <a class="abuse-mailto" href="mailto:phishing@averrow.ca?subject=Phishing%20report">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M3 5h18v14H3z" />
          <path d="M3 5l9 8 9-8" />
        </svg>
        phishing@averrow.ca
      </a>
    </div>

    <div class="abuse-card">
      <div class="abuse-card-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="8" r="4" />
          <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8" />
          <path d="M16.5 5.5l3 3" />
          <path d="M19.5 5.5l-3 3" />
        </svg>
      </div>
      <div class="abuse-card-title">Brand Impersonation</div>
      <div class="abuse-card-desc">
        Fake social account, lookalike domain, or website pretending to
        be a brand. Include as much identifying info as you can.
      </div>
      <ul class="abuse-card-checklist">
        <li>Full URL or social handle (e.g. @brandname_support)</li>
        <li>Screenshots of the impersonating profile or site</li>
        <li>The brand being impersonated</li>
      </ul>
      <a class="abuse-mailto" href="mailto:abuse@averrow.ca?subject=Impersonation%20report">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M3 5h18v14H3z" />
          <path d="M3 5l9 8 9-8" />
        </svg>
        abuse@averrow.ca
      </a>
    </div>

    <div class="abuse-card">
      <div class="abuse-card-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6z" />
          <path d="M9 12l2 2 4-4" />
        </svg>
      </div>
      <div class="abuse-card-title">Counterfeit or Fraud</div>
      <div class="abuse-card-desc">
        Counterfeit storefronts, fake invoices, fraud schemes using a
        brand&rsquo;s name. Same intake as impersonation &mdash; we
        route internally.
      </div>
      <ul class="abuse-card-checklist">
        <li>URL of the counterfeit listing or storefront</li>
        <li>Invoice or message text if you have it</li>
        <li>Brand affected and any payment instructions sent to you</li>
      </ul>
      <a class="abuse-mailto" href="mailto:abuse@averrow.ca?subject=Counterfeit%20or%20fraud%20report">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M3 5h18v14H3z" />
          <path d="M3 5l9 8 9-8" />
        </svg>
        abuse@averrow.ca
      </a>
    </div>
  </div>

  <section class="abuse-process">
    <div class="section-label" style="text-align:center;">What Happens Next</div>
    <h2>Every report goes through the same three steps.</h2>
    <p>Fully automated. You&rsquo;ll get an acknowledgment within seconds and a determination within an hour.</p>

    <div class="abuse-process-grid">
      <div class="abuse-step">
        <div class="abuse-step-num">Step 01</div>
        <div class="abuse-step-title">Instant acknowledgment</div>
        <div class="abuse-step-desc">Within seconds you receive an email confirming we got your submission, with a tracking reference for any follow-up.</div>
      </div>
      <div class="abuse-step">
        <div class="abuse-step-num">Step 02</div>
        <div class="abuse-step-title">Deep inspection</div>
        <div class="abuse-step-desc">The Averrow platform extracts indicators (URLs, sender headers, sending IP, payload signatures), classifies the message, and correlates it against our threat-intel feeds. Typically completes within the hour.</div>
      </div>
      <div class="abuse-step">
        <div class="abuse-step-num">Step 03</div>
        <div class="abuse-step-title">Determination email</div>
        <div class="abuse-step-desc">You receive a follow-up with our verdict &mdash; malicious content discovered, or we believe it&rsquo;s safe &mdash; plus confidence and any action we&rsquo;ve taken (IOCs into platform intel, takedown evidence, partner signal).</div>
      </div>
    </div>
  </section>

  <div class="abuse-privacy" role="note">
    <strong>We don&rsquo;t share your details.</strong>
    Your email address and any personal information in the body stay
    internal to Averrow&rsquo;s analyst team. Indicators (URLs, domains,
    sender IPs, file hashes) may be shared with platform partners and
    threat-intel feeds to help with takedowns.
  </div>

  <div class="abuse-footer-cta">
    Not an abuse report? Reach the team via
    <a href={`${base}/contact`}>/contact</a> for sales, support, or general questions.
  </div>
</Layout>

<style>
  .abuse-hero { padding: 5rem 0 2rem; text-align: center; }
  .abuse-hero .section-title {
    max-width: 100%;
    margin: 0 auto 1rem;
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 800;
  }
  .abuse-hero .section-desc {
    max-width: 620px;
    margin: 0 auto;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .abuse-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin: 2.5rem auto;
    max-width: 1200px;
    padding: 0 24px;
  }

  .abuse-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .abuse-card:hover {
    border-color: rgba(229,168,50,0.4);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }
  :global([data-theme="light"]) .abuse-card {
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(226,221,213,0.5);
    box-shadow: 0 4px 24px rgba(0,0,0,0.03), inset 0 1px 0 rgba(255,255,255,0.9);
  }

  .abuse-card-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-bg);
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .abuse-card-icon svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .abuse-card-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    color: var(--text-primary);
  }
  .abuse-card-desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 1rem;
  }

  .abuse-card-checklist {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--text-secondary);
  }
  .abuse-card-checklist li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    line-height: 1.4;
  }
  .abuse-card-checklist li::before {
    content: "";
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--amber);
    margin-top: 8px;
    flex-shrink: 0;
  }

  .abuse-mailto {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    padding: 0.65rem 1rem;
    border-radius: var(--radius-sm);
    background: var(--accent-bg);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid transparent;
    transition: all 0.2s;
    align-self: flex-start;
  }
  .abuse-mailto:hover {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
    text-decoration: none;
    box-shadow: 0 0 18px rgba(200,60,60,0.25);
  }
  .abuse-mailto svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .abuse-process {
    max-width: 1100px;
    margin: 3rem auto 0;
    padding: 0 24px;
  }
  .abuse-process h2 {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 700;
    text-align: center;
    margin-bottom: 0.4rem;
  }
  .abuse-process > p {
    text-align: center;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto;
  }
  .abuse-process-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 1.5rem;
  }
  .abuse-step {
    padding: 1.25rem 1.5rem;
    border-left: 2px solid var(--amber);
    background: var(--bg-tertiary);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  :global([data-theme="light"]) .abuse-step { background: rgba(255,255,255,0.55); }
  .abuse-step-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 0.5rem;
  }
  .abuse-step-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .abuse-step-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .abuse-privacy {
    max-width: 720px;
    margin: 2.5rem auto 0;
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius-md);
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    text-align: center;
  }
  :global([data-theme="light"]) .abuse-privacy { background: rgba(255,255,255,0.55); }
  .abuse-privacy strong {
    color: var(--text-primary);
    display: block;
    margin-bottom: 0.3rem;
    font-family: var(--font-display);
    font-size: 0.95rem;
  }

  .abuse-footer-cta {
    text-align: center;
    padding: 3rem 0 4rem;
    font-size: 0.92rem;
    color: var(--text-secondary);
  }
  .abuse-footer-cta a {
    color: var(--accent);
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .abuse-grid,
    .abuse-process-grid { grid-template-columns: 1fr; }
  }
</style>
