---
/*
 * Documentation hub. Landing page for /docs — routes to the real
 * product surfaces (getting-started walkthrough, the platform deep
 * dives, integrations, account & billing). Deliberately NOT an API
 * reference: no endpoints/payloads are documented here (see the
 * "Request API Access" callout below) — see docs/archive P3 brief,
 * "docs honesty rule."
 */
import Layout from "../../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const topics = [
  {
    href: "/docs/getting-started",
    icon: "play",
    title: "Getting Started",
    desc: "Run your first scan, add a brand, and get your Brand Exposure Score in five steps.",
    tag: "Start here",
  },
  {
    href: "/platform/ai-agents",
    icon: "activity",
    title: "Brand Exposure Score",
    desc: "The composite score the agent mesh fuses from threats, email posture, social, and domain signal.",
    tag: "Concept",
  },
  {
    href: "/platform/threat-detection",
    icon: "shield",
    title: "Threat Detection",
    desc: "Phishing databases, malware feeds, CT logs, and DNS intelligence &mdash; deduped and AI-assessed.",
    tag: "Platform",
  },
  {
    href: "/platform/email-security",
    icon: "mail",
    title: "Email Security Posture",
    desc: "SPF, DKIM, DMARC, and MX graded A+ through F, with multi-selector DKIM verification.",
    tag: "Platform",
  },
  {
    href: "/platform/social-monitoring",
    icon: "users",
    title: "Social Monitoring",
    desc: "Impersonation and handle-squatting detection across six platforms, with AI confidence scoring.",
    tag: "Platform",
  },
  {
    href: "/platform/ai-agents",
    icon: "cpu",
    title: "AI Agents",
    desc: "Inside the 42-agent mesh &mdash; threat detection, scoring & triage, strategic intel, DNS resolution, geo & provider mapping, and timeline & narrative.",
    tag: "Platform",
  },
  {
    href: "/partners",
    icon: "link",
    title: "Integrations",
    desc: "STIX/TAXII, REST API, webhooks, and email are live today. Slack, Splunk, QRadar, and Sentinel are on the roadmap.",
    tag: "Integrations",
  },
  {
    href: "/pricing",
    icon: "card",
    title: "Account & Billing",
    desc: "Plans, upgrades, and what's included at each tier &mdash; Free Scan through Enterprise.",
    tag: "Account",
  },
];

const icons: Record<string, string> = {
  play: '<circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16"/>',
  activity: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  mail: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  cpu: '<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>',
  link: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>',
  card: '<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>',
};
---

<Layout
  title="Documentation — Averrow"
  description="Digital Risk Protection (DRPS) platform docs: getting started, the Brand Exposure Score, threat detection, email security, social monitoring, and integrations."
>
  <section class="docs-hub-hero">
    <div class="container">
      <div class="section-label" style="text-align:center;">Documentation</div>
      <h1>Documentation</h1>
      <p class="docs-hub-lede">
        How Averrow's platform actually works &mdash; in plain language.
        Start with the getting-started walkthrough, then go deeper on any
        capability below.
      </p>
    </div>
  </section>

  <section class="docs-hub-start">
    <div class="container">
      <a href={`${base}/docs/getting-started`} class="docs-hub-start-card">
        <div class="docs-hub-start-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.play} />
        </div>
        <div class="docs-hub-start-text">
          <div class="docs-hub-start-eyebrow">New to Averrow?</div>
          <h2>Get started in five steps</h2>
          <p>Run a free scan, add your brand, understand your Brand Exposure Score, set up alerts, and connect a live integration.</p>
        </div>
        <span class="docs-hub-start-cta">Start the walkthrough &rarr;</span>
      </a>
    </div>
  </section>

  <section class="docs-hub-grid-section">
    <div class="container">
      <div class="section-label" style="text-align:center;">Browse by Topic</div>
      <h2 class="docs-hub-grid-h2">Everything the platform does, documented</h2>
      <div class="docs-hub-grid">
        {topics.map((t) => (
          <a href={`${base}${t.href}`} class="docs-hub-card">
            <div class="docs-hub-card-top">
              <div class="docs-hub-card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[t.icon]} />
              </div>
              <span class="docs-hub-card-tag">{t.tag}</span>
            </div>
            <div class="docs-hub-card-title">{t.title}</div>
            <p class="docs-hub-card-desc" set:html={t.desc} />
            <span class="docs-hub-card-link">Read more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="docs-hub-api">
    <div class="container docs-hub-api-inner">
      <div class="docs-hub-api-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      </div>
      <div class="docs-hub-api-text">
        <h3>Need API reference detail?</h3>
        <p>
          This hub covers the product flow, not endpoint-level API reference.
          If you need REST API credentials, STIX/TAXII feed access, or
          webhook setup help, request API access and someone on the team
          will walk you through it directly.
        </p>
      </div>
      <a href={`${base}/contact`} class="btn btn-outline docs-hub-api-btn">Request API Access</a>
    </div>
  </section>

  <section class="docs-hub-cta">
    <div class="container">
      <h2>See what Averrow finds for your brand.</h2>
      <p>Run a free exposure scan in under five minutes, or book a demo to see the platform end to end.</p>
      <div class="docs-hub-cta-actions">
        <a href={`${base}/demo`} class="btn btn-primary">Get a Demo</a>
        <a href={`${base}/scan`} class="btn btn-outline">Run a Free Scan</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── HERO ── */
  .docs-hub-hero {
    padding: 4.5rem 0 2.5rem;
    text-align: center;
    background: var(--gradient-hero);
  }
  .docs-hub-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.1;
  }
  .docs-hub-lede {
    font-size: 17px;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── START CARD ── */
  .docs-hub-start { padding: 2.5rem 0 1rem; }
  .docs-hub-start-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
    padding: 1.75rem 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(229,168,50,0.28);
    background: rgba(229,168,50,0.07);
    text-decoration: none;
    color: inherit;
    transition: all 0.25s;
  }
  .docs-hub-start-card:hover {
    border-color: rgba(229,168,50,0.5);
    transform: translateY(-3px);
    box-shadow: 0 10px 28px rgba(0,0,0,0.18);
    text-decoration: none;
  }
  .docs-hub-start-icon {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    background: rgba(229,168,50,0.14);
    color: var(--amber);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .docs-hub-start-icon svg { width: 26px; height: 26px; }
  .docs-hub-start-text { flex: 1; min-width: 0; }
  .docs-hub-start-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 0.3rem;
  }
  .docs-hub-start-text h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }
  .docs-hub-start-text p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0;
  }
  .docs-hub-start-cta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--amber);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── TOPIC GRID ── */
  .docs-hub-grid-section { padding: 3rem 0 3.5rem; }
  .docs-hub-grid-h2 {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 2.25rem;
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 700;
    line-height: 1.25;
  }
  .docs-hub-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .docs-hub-card {
    display: flex;
    flex-direction: column;
    background: rgba(14,26,43,0.5);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.4rem 1.35rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s;
  }
  :global([data-theme="light"]) .docs-hub-card { background: rgba(255,255,255,0.6); }
  .docs-hub-card:hover {
    border-color: rgba(229,168,50,0.4);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    text-decoration: none;
  }
  .docs-hub-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.9rem;
  }
  .docs-hub-card-icon {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-md);
    background: var(--accent-bg);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .docs-hub-card-icon svg { width: 19px; height: 19px; }
  .docs-hub-card-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 0.18rem 0.55rem;
  }
  .docs-hub-card-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.02rem;
    margin-bottom: 0.5rem;
  }
  .docs-hub-card-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0.9rem;
    flex: 1;
  }
  .docs-hub-card-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--amber);
  }

  /* ── API CALLOUT ── */
  .docs-hub-api {
    padding: 2.5rem 0;
    background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
  }
  .docs-hub-api-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: 900px;
  }
  .docs-hub-api-icon {
    width: 46px;
    height: 46px;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    background: var(--green-bg);
    color: var(--green-text);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .docs-hub-api-icon svg { width: 22px; height: 22px; }
  .docs-hub-api-text { flex: 1; min-width: 0; }
  .docs-hub-api-text h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }
  .docs-hub-api-text p {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }
  .docs-hub-api-btn { flex-shrink: 0; white-space: nowrap; }

  /* ── CTA ── */
  .docs-hub-cta { padding: 3.5rem 0; text-align: center; }
  .docs-hub-cta h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .docs-hub-cta p {
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto 2rem;
  }
  .docs-hub-cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── LIGHT THEME CONTRAST OVERRIDES ──
     Amber-as-text eyebrow/CTA/link labels and the API icon's severity
     tint are tuned for dark backgrounds and drop below WCAG AA
     (4.5:1) as text on the light theme's pale tinted pills/sections.
     Darkened here for [data-theme="light"] only; dark theme values
     are untouched. */
  :global([data-theme="light"]) .docs-hub-start-eyebrow { color: var(--accent-section, #8A5F0F); }
  :global([data-theme="light"]) .docs-hub-start-cta { color: var(--accent-section, #8A5F0F); }
  :global([data-theme="light"]) .docs-hub-card-link { color: var(--accent-section, #8A5F0F); }
  :global([data-theme="light"]) .docs-hub-api-icon { color: #106b32; }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .docs-hub-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .docs-hub-start-card { flex-direction: column; align-items: flex-start; text-align: left; }
    .docs-hub-start-cta { align-self: flex-start; }
    .docs-hub-api-inner { flex-direction: column; align-items: flex-start; text-align: left; }
    .docs-hub-api-btn { align-self: flex-start; }
  }
  @media (max-width: 560px) {
    .docs-hub-grid { grid-template-columns: 1fr; }
  }
</style>
