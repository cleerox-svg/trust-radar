<script>
  // Sticky sub-nav scroll-spy: highlight the tab matching the section
  // currently most in view.
  (function () {
    const sections = ["detect", "scoring", "permutation", "evidence", "platforms"];
    const tabs = document.querySelectorAll<HTMLAnchorElement>(".sm-tab");
    if (!("IntersectionObserver" in window)) return;
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tabs.forEach(t => t.classList.remove("active"));
            const match = document.querySelector<HTMLAnchorElement>(`.sm-tab[href="#${entry.target.id}"]`);
            match?.classList.add("active");
          }
        });
      },
      { threshold: 0.35 },
    );
    sections.forEach(id => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  })();
</script>
