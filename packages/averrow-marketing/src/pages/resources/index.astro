---
/*
 * Resources hub. The top-nav "Resources" destination — aggregates the
 * real destinations that already exist on the site (blog, docs,
 * changelog, free scan, platform deep-dives, security) plus a small
 * "latest from the blog" teaser pulled live from the content collection.
 * No fabricated whitepapers/reports — see docs/archive P3 brief.
 */
import Layout from "../../layouts/Layout.astro";
import { getSortedBlogPosts, formatDate } from "../../lib/blog";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const posts = await getSortedBlogPosts();
const latest = posts.slice(0, 3);

const categories = [
  {
    label: "Guides & Research",
    desc: "Long-form threat research and product guides from the Averrow team.",
    href: "/blog",
    cta: "Read the blog",
    icon: "book",
  },
  {
    label: "Product Docs",
    desc: "How Averrow works, from your first scan to a live integration.",
    href: "/docs",
    cta: "Read the docs",
    icon: "code",
  },
  {
    label: "Release Notes",
    desc: "What shipped, when — every feature and fix, in plain language.",
    href: "/changelog",
    cta: "View the changelog",
    icon: "branch",
  },
  {
    label: "Free Brand Exposure Scan",
    desc: "Run a live scan against your domain in under five minutes. No signup, no credit card.",
    href: "/",
    cta: "Run a free scan",
    icon: "radar",
  },
  {
    label: "Platform Deep-Dives",
    desc: "Threat detection, email posture, social monitoring, and the agent mesh — explained in depth.",
    href: "/platform",
    cta: "Explore the platform",
    icon: "layers",
  },
  {
    label: "Security & Trust",
    desc: "Data handling, compliance posture, and what protects your account.",
    href: "/security",
    cta: "See security & trust",
    icon: "shield",
  },
] as const;
---

<Layout
  title="Resources — Averrow"
  description="Guides, product docs, release notes, and platform deep-dives — everything you need to get the most out of Averrow's threat intelligence platform."
>
  <section class="res-hero">
    <div class="container">
      <p class="res-label">Resources</p>
      <h1>Everything you need to <span class="res-accent">know your exposure.</span></h1>
      <p class="res-sub">
        Guides, documentation, release notes, and platform deep-dives &mdash;
        in one place.
      </p>
    </div>
  </section>

  <section class="res-grid-section">
    <div class="container">
      <div class="res-grid">
        {categories.map(cat => (
          <a class="res-card" href={`${base}${cat.href}`}>
            <div class={`res-card-icon res-icon-${cat.icon}`} aria-hidden="true">
              {cat.icon === "book" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4.5A2.5 2.5 0 0 1 4.5 2H19a1 1 0 0 1 1 1v15.5"/><path d="M4.5 22H19a1 1 0 0 0 1-1v-2.5H6a2 2 0 0 0-2 2 2 2 0 0 0 2 2z"/><path d="M4.5 2A2.5 2.5 0 0 0 2 4.5v13A2.5 2.5 0 0 0 4.5 20H6"/></svg>
              )}
              {cat.icon === "code" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              )}
              {cat.icon === "branch" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>
              )}
              {cat.icon === "radar" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="5.5"/><circle cx="12" cy="12" r="1.25" fill="currentColor" stroke="none"/><path d="M12 12 L19 6"/></svg>
              )}
              {cat.icon === "layers" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
              )}
              {cat.icon === "shield" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              )}
            </div>
            <h2 class="res-card-title">{cat.label}</h2>
            <p class="res-card-desc">{cat.desc}</p>
            <span class="res-card-link">{cat.cta} &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {latest.length > 0 && (
    <section class="res-latest-section">
      <div class="container">
        <div class="res-latest-head">
          <div>
            <p class="res-label">Latest from the blog</p>
            <h2>Recent guides &amp; research</h2>
          </div>
          <a class="res-latest-all" href={`${base}/blog`}>View all posts &rarr;</a>
        </div>
        <div class="res-latest-grid">
          {latest.map(post => (
            <a class="res-latest-card" href={`${base}/blog/${post.slug}`}>
              <div class="res-latest-meta">
                <span class="res-latest-badge">{post.data.category}</span>
                <span class="res-latest-read">{post.data.readingMinutes} min read</span>
              </div>
              <h3 class="res-latest-title">{post.data.title}</h3>
              <p class="res-latest-excerpt">{post.data.excerpt}</p>
              <time class="res-latest-date" datetime={post.data.publishedAt}>{formatDate(post.data.publishedAt)}</time>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="res-cta">
    <div class="container">
      <h2>Ready to see what&rsquo;s already targeting your brand?</h2>
      <p>Run a free exposure scan in under five minutes, or talk to us about a full deployment.</p>
      <div class="res-cta-actions">
        <a href={`${base}/demo`} class="btn btn-primary">Get a Demo</a>
        <a href={`${base}/`} class="btn btn-outline">Run a Free Scan</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── HERO ── */
  .res-hero {
    padding: 5rem 0 3rem;
    text-align: center;
    background: var(--gradient-hero);
  }
  .res-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--amber);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.85rem;
  }
  .res-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .res-accent { color: var(--amber); }
  .res-sub {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── CATEGORY GRID ── */
  .res-grid-section { padding: 1rem 0 3rem; }
  .res-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .res-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    position: relative;
    overflow: hidden;
  }
  .res-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    opacity: 0;
    transition: opacity 0.25s;
    background: var(--amber);
  }
  .res-card:hover {
    border-color: var(--amber);
    box-shadow: var(--shadow-glow);
    transform: translateY(-3px);
    text-decoration: none;
  }
  .res-card:hover::before { opacity: 1; }
  :global([data-theme="light"]) .res-card {
    background: rgba(255,255,255,0.6);
    border-color: rgba(226,221,213,0.5);
    box-shadow: 0 4px 24px rgba(0,0,0,0.03), inset 0 1px 0 rgba(255,255,255,0.9);
  }

  .res-card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    margin-bottom: 1.1rem;
    background: var(--accent-bg);
    color: var(--accent);
  }
  .res-card-icon svg { width: 24px; height: 24px; }
  .res-icon-radar { background: var(--green-bg); color: var(--green); }
  .res-icon-layers { background: rgba(10,138,181,0.10); color: var(--blue); }
  .res-icon-shield { background: rgba(229,168,50,0.10); color: var(--amber); }

  .res-card-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .res-card-desc {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex: 1;
  }
  .res-card-link {
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--amber);
  }

  /* ── LATEST FROM THE BLOG ── */
  .res-latest-section {
    padding: 3rem 0;
    background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
  }
  .res-latest-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.75rem;
    flex-wrap: wrap;
  }
  .res-latest-head h2 {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 700;
  }
  .res-latest-all {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--amber);
    white-space: nowrap;
  }
  .res-latest-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .res-latest-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
  }
  .res-latest-card:hover {
    border-color: var(--amber);
    transform: translateY(-2px);
    text-decoration: none;
  }
  :global([data-theme="light"]) .res-latest-card {
    background: rgba(255,255,255,0.6);
    border-color: rgba(226,221,213,0.5);
  }
  .res-latest-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.85rem;
  }
  .res-latest-badge {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.22rem 0.6rem;
    border-radius: 100px;
    background: rgba(229,168,50,0.10);
    color: var(--amber);
    border: 1px solid rgba(229,168,50,0.25);
  }
  .res-latest-read {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-tertiary);
  }
  .res-latest-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }
  .res-latest-excerpt {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
    flex: 1;
  }
  .res-latest-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-tertiary);
  }

  /* ── CTA ── */
  .res-cta { padding: 3.5rem 0; text-align: center; }
  .res-cta h2 {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 34px);
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .res-cta p {
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto 2rem;
  }
  .res-cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .res-grid { grid-template-columns: repeat(2, 1fr); }
    .res-latest-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .res-grid { grid-template-columns: 1fr; }
    .res-latest-grid { grid-template-columns: 1fr; }
  }
</style>
