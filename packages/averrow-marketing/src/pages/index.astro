---
// R1 skeleton page.
//
// This file proves the build pipeline end-to-end: Astro builds, output lands
// in the trust-radar Worker's static-assets directory, the Worker serves it
// at /marketing/. R2 replaces this with the real Layout + first ported route.
//
// Visible at: https://staging.averrow.com/marketing/  (and production while
// gated under /marketing/* — production site at / is unchanged until R6.)
const buildTime = new Date().toISOString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Marketing rebuild — R1 skeleton — Averrow</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #060A14;
        --card: #0E1A2B;
        --border: rgba(255, 255, 255, 0.08);
        --text: rgba(255, 255, 255, 0.92);
        --muted: rgba(255, 255, 255, 0.55);
        --amber: #E5A832;
      }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
        display: grid;
        place-items: center;
        padding: 24px;
      }
      .card {
        max-width: 640px;
        width: 100%;
        padding: 32px;
        border-radius: 12px;
        background: var(--card);
        border: 1px solid var(--border);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      }
      .kicker {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--amber);
        margin-bottom: 12px;
      }
      h1 {
        font-size: 24px;
        font-weight: 700;
        margin: 0 0 16px;
        letter-spacing: -0.01em;
      }
      p {
        color: var(--muted);
        font-size: 14px;
        line-height: 1.6;
        margin: 0 0 16px;
      }
      .meta {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 11px;
        color: var(--muted);
        padding-top: 16px;
        border-top: 1px solid var(--border);
      }
      .meta strong { color: var(--text); }
      a { color: var(--amber); }
    </style>
  </head>
  <body>
    <main class="card">
      <div class="kicker">Marketing rebuild · R1 · Skeleton</div>
      <h1>Astro + MDX skeleton is live.</h1>
      <p>
        This page exists to prove the build pipeline. Astro built, the static
        artifacts were written into the trust-radar Worker&rsquo;s assets
        directory, and the Worker served the file at <code>/marketing/</code>
        via its existing Static Assets binding.
      </p>
      <p>
        Production routes (<a href="/">/</a>, <a href="/platform">/platform</a>,
        etc.) are still served from the inline TypeScript templates &mdash; this
        rebuild is gated under <code>/marketing/*</code> until R6 ships the
        cutover. See <a href="/" target="_blank">docs/marketing-rebuild-evaluation.md</a>
        for the phase plan.
      </p>
      <div class="meta">
        <strong>Built at:</strong> {buildTime}
      </div>
    </main>
  </body>
</html>
