<script>
  // Sticky cap-nav scroll-spy: set the active tab to the section
  // currently most in view as the user scrolls.
  (function () {
    const sections = ["monitoring", "email-posture", "social", "agents"];
    const tabs = document.querySelectorAll<HTMLAnchorElement>(".cap-tab");
    if (!("IntersectionObserver" in window)) return;
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tabs.forEach(t => t.classList.remove("active"));
            const match = document.querySelector<HTMLAnchorElement>(`.cap-tab[href="#${entry.target.id}"]`);
            match?.classList.add("active");
          }
        });
      },
      { threshold: 0.4 },
    );
    sections.forEach(id => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  })();
</script>
