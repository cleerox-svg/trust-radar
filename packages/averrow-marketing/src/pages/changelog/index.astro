---
/*
 * Changelog page. Mirrors the existing /changelog visual (timeline +
 * kind filter chips + RSS pill) but renders from the manifest in
 * src/data/changelog-entries.ts. RSS feed is the sibling file
 * feed.xml.ts (Astro RSS integration, ported in R3).
 *
 * Filter chips run on a tiny inline script — overkill to ship a React
 * island for one toggle group.
 */
import Layout from "../../layouts/Layout.astro";
import {
  sortedEntries,
  formatDate,
  ALL_KINDS,
  kindSlug,
} from "../../data/changelog-entries";

const entries = sortedEntries();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
  title="Changelog — Averrow | AI-Powered Brand Threat Intelligence"
  description="A timeline of features, improvements, and fixes shipping in Averrow."
>
  <section class="changelog-hero">
    <div class="container">
      <p class="section-label">Changelog</p>
      <h1>What&rsquo;s New</h1>
      <p>A timeline of features, improvements, and fixes shipping in Averrow.</p>
      <div class="changelog-hero-actions">
        <a
          class="changelog-rss"
          href={`${base}/changelog/feed.xml`}
          aria-label="Subscribe to the Averrow changelog via RSS"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <circle cx="6.18" cy="17.82" r="2.18" />
            <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83C19.56 11.41 12.59 4.44 4 4.44zm0 5.66v2.83c3.91 0 7.07 3.16 7.07 7.07h2.83c0-5.46-4.44-9.9-9.9-9.9z" />
          </svg>
          RSS
        </a>
      </div>
    </div>
  </section>

  <div class="changelog-filter-strip" role="tablist" aria-label="Filter entries by kind">
    <button type="button" class="changelog-filter-chip active" data-filter="all" role="tab" aria-selected="true">All</button>
    {ALL_KINDS.map(kind => (
      <button type="button" class="changelog-filter-chip" data-filter={kind} role="tab" aria-selected="false">{kind}</button>
    ))}
  </div>

  <hr class="tr-divider" />

  <section class="changelog-section">
    <div class="container">
      <div class="timeline" id="changelog-timeline">
        {entries.map(entry => {
          const slug = kindSlug(entry.kind);
          return (
            <div class="timeline-entry" data-kind={entry.kind}>
              <div class="timeline-card">
                <div class="timeline-meta">
                  <time class="timeline-date" datetime={entry.publishedAt}>
                    {formatDate(entry.publishedAt)}
                  </time>
                  <span class="timeline-version">{entry.version}</span>
                  <span class={`changelog-badge changelog-badge-${slug}`}>{entry.kind}</span>
                </div>
                <h3 class="timeline-title">{entry.title}</h3>
                <p class="timeline-desc">{entry.description}</p>
              </div>
            </div>
          );
        })}
      </div>
      <div class="changelog-empty" id="changelog-empty" style="display:none;">
        No entries in this category yet.
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Scoped to this page — Astro auto-namespaces. */
  .changelog-hero {
    padding: 5rem 0 2.5rem;
    text-align: center;
    background: var(--gradient-hero);
  }
  .changelog-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: 1rem;
  }
  .changelog-hero p {
    font-size: 1.08rem;
    color: var(--text-secondary);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.75;
  }
  .changelog-hero-actions {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .changelog-rss {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--amber);
    border: 1px solid rgba(229, 168, 50, 0.30);
    background: rgba(229, 168, 50, 0.06);
    padding: 0.45rem 0.8rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .changelog-rss:hover {
    background: rgba(229, 168, 50, 0.12);
    border-color: rgba(229, 168, 50, 0.50);
    color: var(--amber);
    text-decoration: none;
  }
  .changelog-rss svg { width: 12px; height: 12px; }

  .changelog-filter-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0 1.5rem 0;
    margin: 1.75rem 0 0.25rem;
  }
  .changelog-filter-chip {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.45rem 1rem;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
  }
  .changelog-filter-chip:hover {
    color: var(--text-primary);
    border-color: var(--amber);
  }
  .changelog-filter-chip.active {
    background: var(--amber);
    color: var(--bg-primary);
    border-color: var(--amber);
    box-shadow: 0 0 12px rgba(229, 168, 50, 0.25);
  }
  :global([data-theme="light"]) .changelog-filter-chip.active { color: #fff; }

  .changelog-empty {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
  }

  .changelog-section { padding: 2.5rem 0; }

  .timeline { position: relative; max-width: 780px; margin: 0 auto; }
  .timeline::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 28px;
    width: 2px;
    background: linear-gradient(180deg, var(--amber), var(--border) 30%, var(--border) 70%, transparent);
    border-radius: 2px;
  }

  .timeline-entry { position: relative; padding-left: 72px; padding-bottom: 3rem; }
  .timeline-entry:last-child { padding-bottom: 0; }
  .timeline-entry.is-hidden { display: none; }

  .timeline-entry::before {
    content: "";
    position: absolute;
    left: 22px;
    top: 6px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg-primary);
    border: 3px solid var(--amber);
    z-index: 2;
    transition: background 0.3s, border-color 0.3s;
  }
  .timeline-entry:hover::before {
    background: var(--amber);
    box-shadow: 0 0 12px rgba(229, 168, 50, 0.4);
  }

  .timeline-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.75rem 2rem;
    transition: all 0.3s;
  }
  .timeline-card:hover {
    border-color: var(--amber);
    box-shadow: var(--shadow-md);
    transform: translateX(4px);
  }

  .timeline-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
    flex-wrap: wrap;
  }
  .timeline-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    letter-spacing: 0.02em;
  }
  .timeline-version {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-secondary);
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
  }

  .changelog-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .changelog-badge-feature {
    background: var(--accent-bg);
    color: var(--accent);
    border: 1px solid rgba(200, 60, 60, 0.2);
  }
  .changelog-badge-improvement {
    background: var(--green-bg);
    color: var(--green);
    border: 1px solid rgba(60, 184, 120, 0.25);
  }
  .changelog-badge-fix {
    background: rgba(229, 168, 50, 0.10);
    color: var(--amber);
    border: 1px solid rgba(229, 168, 50, 0.25);
  }
  .changelog-badge-security {
    background: rgba(248, 113, 113, 0.10);
    color: var(--sev-critical);
    border: 1px solid rgba(248, 113, 113, 0.30);
  }

  .timeline-title {
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }
  .timeline-desc {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  @media (max-width: 640px) {
    .changelog-hero { padding: 5rem 0 2rem; }
    .changelog-section { padding: 2rem 0; }
    .timeline::before { left: 18px; }
    .timeline-entry { padding-left: 52px; }
    .timeline-entry::before { left: 12px; width: 12px; height: 12px; top: 8px; }
    .timeline-card { padding: 1.25rem 1.5rem; }
    .timeline-meta { gap: 0.5rem; }
    .changelog-filter-strip { gap: 0.4rem; }
    .changelog-filter-chip { font-size: 0.66rem; padding: 0.35rem 0.7rem; }
  }

  :global([data-theme="light"]) .timeline-card {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-color: rgba(226, 221, 213, 0.5);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.03), inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }
  :global([data-theme="light"]) .timeline-card:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.9);
    border-color: rgba(226, 221, 213, 0.7);
  }
</style>

<script>
  // Filter chip toggling. Pure DOM, no framework — single button group.
  (function () {
    const chips = document.querySelectorAll<HTMLButtonElement>(".changelog-filter-chip");
    const entries = document.querySelectorAll<HTMLElement>(".timeline-entry");
    const empty = document.getElementById("changelog-empty");

    function applyFilter(filter: string) {
      let visible = 0;
      entries.forEach(entry => {
        const match = filter === "all" || entry.getAttribute("data-kind") === filter;
        entry.classList.toggle("is-hidden", !match);
        if (match) visible++;
      });
      if (empty) empty.style.display = visible === 0 ? "block" : "none";
    }

    chips.forEach(chip => {
      chip.addEventListener("click", () => {
        chips.forEach(c => {
          c.classList.remove("active");
          c.setAttribute("aria-selected", "false");
        });
        chip.classList.add("active");
        chip.setAttribute("aria-selected", "true");
        applyFilter(chip.getAttribute("data-filter") ?? "all");
      });
    });
  })();
</script>
