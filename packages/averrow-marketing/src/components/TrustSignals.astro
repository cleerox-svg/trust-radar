---
/*
 * Trust signals strip — target-sector icons + a factual trust-posture
 * card (compliance + security posture; no customer claims until real
 * proof exists). Used on / (R5) and /pricing (R4).
 *
 * Wrap the import site in a <section class="trust-signals">
 * — that's where the outer padding lives in global.css.
 */

interface Sector {
  label: string;
  title: string;
  svg: string;
}

const SVG_ATTRS =
  'viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"';

const sectors: Sector[] = [
  {
    label: "Fintech",
    title: "Financial services",
    svg: `<svg ${SVG_ATTRS}><path d="M3 21h18"/><path d="M5 21V10"/><path d="M19 21V10"/><path d="M9 21v-7"/><path d="M15 21v-7"/><path d="M3 10l9-6 9 6"/></svg>`,
  },
  {
    label: "SaaS",
    title: "Software / SaaS",
    svg: `<svg ${SVG_ATTRS}><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 10h18"/><path d="M8 18l-2 4"/><path d="M16 18l2 4"/></svg>`,
  },
  {
    label: "Healthcare",
    title: "Healthcare",
    svg: `<svg ${SVG_ATTRS}><path d="M12 21s-7-4.5-7-11a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 6.5-7 11-7 11z" transform="translate(-2 0)"/><path d="M9 12h2v-2h2v2h2v2h-2v2h-2v-2H9z"/></svg>`,
  },
  {
    label: "E-commerce",
    title: "Retail / E-commerce",
    svg: `<svg ${SVG_ATTRS}><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 1 1-8 0"/></svg>`,
  },
  {
    label: "Media",
    title: "Media / Publishing",
    svg: `<svg ${SVG_ATTRS}><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`,
  },
  {
    label: "Marketing",
    title: "Marketing / Agencies",
    svg: `<svg ${SVG_ATTRS}><path d="M3 11l18-7v16l-18-7"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>`,
  },
];
---

<div class="trust-strip-label">Built to protect brands across</div>
<div class="trust-strip-grid">
  {sectors.map(s => (
    <div class="trust-sector" title={s.title}>
      <div class="trust-sector-icon" set:html={s.svg} />
      <div class="trust-sector-label">{s.label}</div>
    </div>
  ))}
</div>

<div class="trust-posture-card">
  <div class="trust-posture-heading">Proof, not promises</div>
  <ul class="trust-posture-list">
    <li><strong>GDPR-aligned, PIPEDA &amp; WCAG 2.1 AA</strong> controls operating today</li>
    <li><strong>SOC 2 Type I</strong> audit scheduled for Q3 2026</li>
    <li><strong>No customer PII stored</strong> &middot; encrypted at rest &middot; TLS 1.3 everywhere</li>
    <li><strong>42 specialized AI agents</strong> across 45+ threat &amp; intelligence feeds</li>
  </ul>
</div>

<style is:global>
  /* These styles are global because the same primitives ship on /
     and /pricing — Astro scoping would namespace per call site. */
  .trust-signals {
    padding: 56px 24px 32px;
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .trust-strip-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 18px;
  }
  .trust-strip-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 36px;
    flex-wrap: wrap;
    margin-bottom: 12px;
    padding: 14px 24px;
  }
  .trust-sector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: var(--text-tertiary);
    opacity: 0.85;
    transition: opacity 0.2s, color 0.2s;
  }
  .trust-sector:hover { opacity: 1; color: var(--text-secondary); }
  .trust-sector-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .trust-sector-icon svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .trust-sector-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .trust-posture-card {
    max-width: 720px;
    margin: 28px auto 0;
    padding: 28px 32px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: var(--glass-card-bg, rgba(22,30,48,0.55));
    backdrop-filter: blur(12px) saturate(160%);
    -webkit-backdrop-filter: blur(12px) saturate(160%);
    text-align: left;
  }
  .trust-posture-heading {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 16px;
  }
  .trust-posture-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 12px;
  }
  .trust-posture-list li {
    position: relative;
    padding-left: 26px;
    font-family: var(--font-display);
    font-size: 15px;
    line-height: 1.5;
    color: var(--text-secondary);
  }
  .trust-posture-list li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--green, #3CB878);
    font-weight: 700;
  }
  .trust-posture-list li strong {
    color: var(--text-primary);
    font-weight: 600;
  }
  @media (max-width: 640px) {
    .trust-strip-grid { gap: 24px; }
    .trust-signals { padding: 40px 16px 24px; }
    .trust-posture-card { padding: 22px 22px; }
    .trust-posture-list li { font-size: 14px; }
  }
</style>
