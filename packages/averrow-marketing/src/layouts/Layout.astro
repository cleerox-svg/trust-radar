---
/*
 * Root document shell — used by every Astro page.
 *
 * Equivalent to wrapPage() in packages/averrow-worker/src/templates/shared.ts.
 * Renders the full <!doctype html>, head meta, pre-paint theme script,
 * top nav, page body, footer.
 *
 * The theme cycle island is mounted inside Nav.astro; this layout
 * just sets data-theme via the pre-paint inline script so first
 * paint matches the user's saved (or OS) preference without flash.
 */
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  /** Optional override for noindex meta (e.g. for the R1 skeleton). */
  noindex?: boolean;
  /** Open Graph / Twitter share image path. Absolute-ized against the site origin. */
  ogImage?: string;
  /** Open Graph type — "website" (default) or "article" for blog posts. */
  ogType?: string;
  /** Optional extra JSON-LD block (e.g. Article on blog posts). */
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  noindex = false,
  ogImage = "/brand/averrow-og.png",
  ogType = "website",
  jsonLd,
} = Astro.props;

const siteOrigin = new URL(Astro.site ?? "https://averrow.com").origin;
const canonical = new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageUrl = new URL(ogImage, siteOrigin).toString();

// Site-wide Organization structured data. Kept factual and on-positioning
// (global threat-intel + brand protection; no aviation/military framing).
const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Averrow",
  url: siteOrigin,
  logo: new URL("/brand/averrow-512.png", siteOrigin).toString(),
  image: ogImageUrl,
  description:
    "AI-first threat intelligence and brand protection — detect and shut down impersonation, phishing, and brand abuse across domains, email, and social.",
  parentOrganization: { "@type": "Organization", name: "LRX Enterprises Inc." },
};
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Averrow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <link rel="icon" href="/favicon.svg?v=2" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icon-192.svg" />
    <link rel="alternate" type="application/rss+xml" title="Averrow Blog" href="/blog/feed.xml" />
    <link rel="alternate" type="application/rss+xml" title="Averrow Changelog" href="/changelog/feed.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      // Pre-paint theme load — avoids a flash. Three modes match the
      // back-end sidebar: auto / dark / light. Auto resolves from
      // prefers-color-scheme. data-theme always ends up either 'dark'
      // or 'light' so CSS rules apply; the saved mode (including 'auto')
      // is what the ThemeCycle island reads on hydration.
      (function () {
        try {
          const saved = localStorage.getItem("averrow-theme");
          let resolved = "dark";
          if (saved === "light" || saved === "dark") {
            resolved = saved;
          } else {
            const prefersLight =
              window.matchMedia &&
              window.matchMedia("(prefers-color-scheme: light)").matches;
            resolved = prefersLight ? "light" : "dark";
          }
          document.documentElement.setAttribute("data-theme", resolved);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#content" class="skip-link">Skip to content</a>
    <Nav />
    <main id="content" class="page-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  /* Accessibility: skip link — visually hidden until keyboard-focused. */
  .skip-link {
    position: absolute;
    left: 0.5rem;
    top: -3rem;
    z-index: 1000;
    padding: 0.6rem 1rem;
    background: var(--amber);
    color: #0b0f1a;
    font-family: var(--font-display);
    font-weight: 700;
    border-radius: 0 0 8px 8px;
    transition: top 0.15s ease;
  }
  .skip-link:focus {
    top: 0;
    outline: 2px solid #0b0f1a;
    outline-offset: 2px;
  }
</style>
