{
  "name": "trust-radar",
  "version": "1.0.0",
  "private": true,
  "description": "Trust Radar — URL & domain trust scoring (lrx-radar.com)",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply radar-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply radar-db --remote",
    "db:create": "wrangler d1 create radar-db"
  },
  "dependencies": {
    "itty-router": "^5.0.18",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.0.0"
  }
}
