{
  "name": "trust-radar",
  "version": "1.0.0",
  "private": true,
  "description": "Trust Radar — URL & domain trust scoring (trustradar.ca)",
  "scripts": {
    "build:manifest": "tsx scripts/build-architect-manifest.ts",
    "check:resource-drift": "tsx scripts/check-resource-drift.ts",
    "audit:agent-standard": "tsx scripts/audit-agent-standard.ts",
    "new-agent": "tsx scripts/new-agent.ts",
    "build": "pnpm build:manifest && wrangler deploy --dry-run --outdir dist",
    "dev": "wrangler dev",
    "deploy": "pnpm build:manifest && wrangler deploy",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "db:migrate:audit:local": "wrangler d1 migrations apply AUDIT_DB --local",
    "db:migrate:audit:prod": "wrangler d1 migrations apply AUDIT_DB --remote",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@averrow/shared": "workspace:*",
    "@simplewebauthn/server": "^11.0.0",
    "itty-router": "^5.0.18",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@simplewebauthn/types": "^11.0.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18",
    "wrangler": "^4.78.0"
  }
}
