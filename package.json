{
  "name": "lrx-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "imprsn8 Platform Monorepo — Guard (social) & Shield (corporate) brand protection",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "deploy:guard": "turbo run deploy --filter=imprsn8",
    "deploy:shield": "turbo run deploy --filter=trust-radar",
    "deploy:api": "turbo run deploy --filter=api",
    "deploy:all": "turbo run deploy",
    "deploy:imprsn8": "turbo run deploy --filter=imprsn8",
    "deploy:radar": "turbo run deploy --filter=trust-radar"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "workerd"]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
