{
  "name": "lrx-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Averrow Platform Monorepo — AI-first threat intelligence & brand protection",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "deploy:shield": "turbo run deploy --filter=trust-radar",
    "deploy:radar": "turbo run deploy --filter=trust-radar"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "workerd"]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
